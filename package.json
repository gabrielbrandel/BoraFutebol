{
  "name": "datesoccer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run api:dev\" \"npm run dev\"",
    "api:dev": "tsx server/dev.ts",
    "build": "prisma generate && vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@primevue/themes": "^4.5.4",
    "@prisma/client": "^6.9.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.5.1",
    "hono": "^4.7.11",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vite-plugin-pwa": "^1.3.0",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-leaflet": "^0.1.0",
    "vue-router": "^4.6.4",
    "workbox-window": "^7.4.1",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.1.2",
    "prisma": "^6.19.3",
    "sass": "^1.101.0",
    "tsx": "^4.19.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
