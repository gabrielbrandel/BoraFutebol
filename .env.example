# === O QUE VAI NO .env (Prisma / API) ===
#
# No Supabase: Connect → ORMs → Prisma → copie as duas URLs:
#
# DATABASE_URL = Transaction pooler (porta 6543) — API na Vercel
# DIRECT_URL   = Direct connection (porta 5432, host db....supabase.co) — npm run db:push
#
# NAO use no .env:
# - https://xxx.supabase.co        (URL do painel, nao e banco)
# - sb_publishable_...             (chave do Supabase JS, este app usa Prisma)
# - supabase login / link          (CLI opcional, nao precisa para rodar o app)

DATABASE_URL="postgresql://postgres.iaxczrfutmzupphqtvvh:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.iaxczrfutmzupphqtvvh.supabase.co:5432/postgres"

JWT_SECRET="DateSoccer_SuperSecretKey_2024_MinLength32Chars!"
JWT_ISSUER="DateSoccer"
JWT_AUDIENCE="DateSoccerApp"
JWT_ACCESS_MINUTES=60
API_PORT=5000
CORS_ORIGINS="http://localhost:5173,https://borafutebol.vercel.app"
VITE_API_URL="/api"
